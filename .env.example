# MaxMind Account Credentials
MAXMIND_ACCOUNT_ID=your_account_id_here
MAXMIND_LICENSE_KEY=your_license_key_here

# Cloudflare API Credentials
# Needs 'edit D1 database' permission only
CLOUDFLARE_API_TOKEN_READ_D1=your_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_D1_DATABASE_ID=value_from_wrangler_config

# Rapid API
RAPID_API_SECRET=your_rapid_api_key_here

# Master keys for direct (non-RapidAPI) access.
# Comma-separated name:key pairs. Name is used only for log tracing.
# MASTER_KEYS=internal-dashboard:abc123,mobile-app:def456

NODE_ENV=development
